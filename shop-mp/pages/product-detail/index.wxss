.container {
  padding: 24rpx;
}

.hero {
  width: 100%;
  height: 360rpx;
  border-radius: 14rpx;
  margin-bottom: 14rpx;
}

.name {
  font-size: 34rpx;
  font-weight: 700;
  margin-bottom: 10rpx;
}

.price {
  color: #1677ff;
  font-weight: 700;
  font-size: 34rpx;
}

.meta {
  margin-top: 14rpx;
}

.stock {
  color: #0a9b4d;
  background: #e8f8ef;
  border-radius: 999rpx;
  padding: 4rpx 14rpx;
  font-size: 22rpx;
}

.qtyRow {
  margin-top: 4rpx;
}

.qty {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.qtyText {
  min-width: 60rpx;
  text-align: center;
  font-weight: 600;
}

.qtyBtn {
  min-width: 56rpx;
}

.orderBtn {
  border: none;
  background: linear-gradient(135deg, #1677ff, #52a7ff);
  color: #fff;
}

