.container {
  padding: 24rpx 24rpx 18rpx;
}

.hero {
  width: 100%;
  height: 420rpx;
  border-radius: 18rpx;
  margin-bottom: 16rpx;
}

.name {
  font-size: 38rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.price {
  color: #1677ff;
  font-weight: 700;
  font-size: 34rpx;
}

.meta {
  margin-top: 16rpx;
}

.stock {
  color: #0a9b4d;
  background: #e8f8ef;
  border-radius: 999rpx;
  padding: 6rpx 14rpx;
  font-size: 22rpx;
}

.qtyRow {
  margin-top: 4rpx;
}

.qty {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: #f3f6fb;
  border: 1rpx solid #e5eaf3;
  border-radius: 999rpx;
  padding: 4rpx;
}

.qtyText {
  min-width: 60rpx;
  text-align: center;
  font-weight: 600;
}

.qtyBtn {
  min-width: 64rpx;
  height: 56rpx;
  line-height: 56rpx;
  border-radius: 999rpx;
  background: #ffffff;
  border: 1rpx solid #e5eaf3;
}

.orderBtn {
  border: none;
  background: linear-gradient(135deg, #1677ff, #52a7ff);
  color: #fff;
  border-radius: 14rpx;
  min-height: 84rpx;
  line-height: 84rpx;
}

