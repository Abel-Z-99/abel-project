.container {
  padding: 32rpx;
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(180deg, #eff6ff 0%, #f7f7f7 40%);
}

.card {
  width: 100%;
  border-radius: 20rpx;
  box-shadow: 0 16rpx 40rpx rgba(22, 119, 255, 0.08);
}

.cover {
  width: 100%;
  height: 220rpx;
  border-radius: 12rpx;
  margin-bottom: 18rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.subtitle {
  margin-bottom: 20rpx;
}

.field {
  margin-bottom: 18rpx;
}

.label {
  display: block;
  margin-bottom: 8rpx;
  color: #333;
}

.input {
  background: #f4f4f4;
  border-radius: 12rpx;
  padding: 18rpx 16rpx;
}

.hint {
  margin-top: 18rpx;
  text-align: center;
}

.loginBtn {
  border: none;
  background: linear-gradient(135deg, #1677ff, #69b1ff);
  color: #fff;
}

