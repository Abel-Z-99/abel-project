<view class="container">
  <block wx:for="{{orders}}" wx:key="id">
    <view class="card order">
      <view class="row">
        <view class="no">{{item.orderNo}}</view>
        <view class="status">{{item.status}}</view>
      </view>
      <view class="muted">金额：¥{{item.totalAmount}}</view>
      <view class="muted">下单：{{item.createdAtFormatted}}</view>
      <view class="items">
        <block wx:for="{{item.items}}" wx:key="productId" wx:for-item="line">
          <view class="row itemRow">
            <view class="muted">{{line.productName}}</view>
            <view class="muted">x{{line.quantity}}</view>
          </view>
        </block>
      </view>
    </view>
  </block>
  <view class="muted footer" wx:if="{{loading}}">加载中...</view>
  <view class="muted footer" wx:if="{{!loading && orders.length===0}}">暂无订单</view>
</view>

