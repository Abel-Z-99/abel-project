.container {
  padding: 24rpx 24rpx 16rpx;
}

.banner {
  height: 300rpx;
  border-radius: 24rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 16rpx 34rpx rgba(22, 119, 255, 0.14);
}

.bannerImg {
  width: 100%;
  height: 100%;
}

.titleRow {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.title {
  font-size: 38rpx;
  font-weight: 700;
  color: #111827;
}

.searchBar {
  display: flex;
  gap: 16rpx;
  align-items: center;
  border-radius: 20rpx;
}

.searchInput {
  flex: 1;
  background: #f3f6fb;
  border: 1rpx solid #e5eaf3;
  border-radius: 14rpx;
  padding: 16rpx 18rpx;
}

.searchBtn {
  background: linear-gradient(135deg, #1677ff, #52a7ff);
  color: #fff;
  border: none;
  border-radius: 12rpx;
  box-shadow: 0 8rpx 20rpx rgba(22, 119, 255, 0.24);
}

.list {
  margin-top: 18rpx;
}

.item {
  margin-bottom: 20rpx;
  border-radius: 20rpx;
  box-shadow: 0 12rpx 28rpx rgba(15, 23, 42, 0.08);
}

.thumb {
  width: 100%;
  height: 280rpx;
  border-radius: 16rpx;
  margin-bottom: 14rpx;
}

.name {
  font-weight: 600;
  font-size: 30rpx;
  color: #0f172a;
  max-width: 70%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.price {
  color: #1677ff;
  font-weight: 600;
}

.desc {
  margin-top: 10rpx;
  font-size: 25rpx;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.meta {
  margin-top: 10rpx;
}

.tag {
  font-size: 22rpx;
  border-radius: 999rpx;
  padding: 4rpx 14rpx;
}

.on {
  color: #0a9b4d;
  background: #e8f8ef;
}

.off {
  color: #b42318;
  background: #feeceb;
}

.footer {
  text-align: center;
  padding: 24rpx 0;
}

