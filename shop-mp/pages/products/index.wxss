.container {
  padding: 24rpx;
}

.banner {
  height: 280rpx;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.bannerImg {
  width: 100%;
  height: 100%;
}

.titleRow {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14rpx;
}

.title {
  font-size: 34rpx;
  font-weight: 700;
}

.searchBar {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.searchInput {
  flex: 1;
  background: #f4f4f4;
  border-radius: 12rpx;
  padding: 16rpx;
}

.searchBtn {
  background: linear-gradient(135deg, #1677ff, #52a7ff);
  color: #fff;
  border: none;
}

.list {
  margin-top: 18rpx;
}

.item {
  margin-bottom: 18rpx;
  border-radius: 18rpx;
  box-shadow: 0 8rpx 24rpx rgba(22, 119, 255, 0.08);
}

.thumb {
  width: 100%;
  height: 250rpx;
  border-radius: 14rpx;
  margin-bottom: 12rpx;
}

.name {
  font-weight: 600;
  font-size: 30rpx;
}

.price {
  color: #1677ff;
  font-weight: 600;
}

.desc {
  margin-top: 10rpx;
}

.meta {
  margin-top: 10rpx;
}

.tag {
  font-size: 22rpx;
  border-radius: 999rpx;
  padding: 4rpx 14rpx;
}

.on {
  color: #0a9b4d;
  background: #e8f8ef;
}

.off {
  color: #b42318;
  background: #feeceb;
}

.footer {
  text-align: center;
  padding: 24rpx 0;
}

